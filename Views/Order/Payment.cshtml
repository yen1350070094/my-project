@model MilkTeaShop.ViewModels.PaymentViewModels
@{
    ViewData["Title"] = "Thanh toan";
    var order = Model.Order;
}

<div class="row justify-content-center">
    <div class="col-lg-7">
        <div class="card shadow-sm border-0 rounded-3 overflow-hidden">

            <div class="card-header bg-white fw-bold border-bottom pt-4">
                Thanh toán đơn hàng
                <span class="text-success ms-2">@order.OrderCode</span>
            </div>

            <div class="card-body p-4">

                @* Chi tiet san pham *@
                <table class="table table-sm mb-4">
                    <thead class="table-light">
                        <tr>
                            <th>Sản phẩm</th>
                            <th>Tùy chỉnh</th>
                            <th class="text-end">Tiền</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in order.OrderItems)
                        {
                            <tr>
                                <td>
                                    @item.Product?.Name
                                    <span class="badge bg-secondary">@item.ProductSize?.SizeName</span>
                                    x@item.Quantity
                                </td>
                                <td class="small text-muted">
                                    @item.SugarLevel?.Label - @item.IceLevel?.Label
                                    @if (item.OrderItemToppings.Any())
                                    {
                                        <br />
                                        <span>@string.Join(", ", item.OrderItemToppings.Select(t => t.Topping!.Name))</span>
                                    }
                                </td>
                                <td class="text-end fw-bold">@item.Subtotal.ToString("N0") d</td>
                            </tr>
                        }
                    </tbody>
                    <tfoot>
                        <tr class="table-success">
                            <td colspan="2" class="fw-bold fs-5">Tong cong</td>
                            <td class="text-end fw-bold fs-5 text-danger">@Model.TotalAmount.ToString("N0") d</td>
                        </tr>
                    </tfoot>
                </table>

                @if (order.PaymentMethod == "Momo")
                {
                    @* Momo - VietQR chuyen khoan *@
                    <div class="text-center mb-4">
                        <div class="alert alert-success py-2">
                            Quét mã QR để chuyển khoản — số tiền và nội dung <strong>tự động điền sẳn</strong>!
                        </div>

                        @if (!string.IsNullOrEmpty(Model.VietQrImageUrl))
                        {
                            <img src="@Model.VietQrImageUrl"
                                 class="rounded border shadow-sm my-3"
                                 width="280"
                                 alt="VietQR MilkTeaShop"
                                 onerror="this.src='https://placehold.co/280x280?text=QR+Error'" />
                        }

                        <div class="d-flex flex-column gap-1 text-muted small">
                            <span>Số tiền: <strong class="text-danger fs-6">@Model.TotalAmount.ToString("N0") d</strong></span>
                            <span>Nội dung: <strong>Thanh toán @order.OrderCode</strong></span>
                            <span>Người nhận: <strong>MilkTeaShop</strong></span>
                        </div>

                        <div class="alert alert-info small mt-3 text-start">
                            <strong>Cách quét:</strong> Mở app ngân hàng hoặc ví điện tử MoMo/ZaloPay, chọn QR, quét mã trên.<br />
                            Sau khi chuyển khoản, nhân viên sẽ xác nhận đơn hàng của bạn trong <strong>5 phút</strong>.
                        </div>

                        @if (User.IsInRole("Employee") || User.IsInRole("Manager") || User.IsInRole("Admin"))
                        {
                            <form asp-action="ConfirmPayment" method="post" class="mt-3">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@order.Id" />
                                <button type="submit" class="btn btn-success w-100 fw-bold rounded-pill py-2">
                                    Xác nhận đã chuyển khoản
                                </button>
                            </form>
                        }
                        else
                        {
                            <div class="alert alert-warning mt-3 text-center">
                                Chờ nhân viên xác nhận
                            </div>
                        }
                    </div>
                }
                else
                {
                    @* Cash - Tien mat *@
                    <div class="alert alert-warning text-center mb-4">
                        <div class="fw-bold fs-5 mb-1">Thanh toán tiền mặt</div>
                        Vui lòng chuẩn bị <strong class="text-danger">@Model.TotalAmount.ToString("N0") d</strong><br />
                        <small class="text-muted">Nhân viên xác nhận sau khi bạn thanh toán</small>
                    </div>

                    @if (User.IsInRole("Employee") || User.IsInRole("Manager") || User.IsInRole("Admin"))
                    {
                        <form asp-action="ConfirmPayment" method="post" class="mb-3">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@order.Id" />
                            <button type="submit" class="btn btn-success w-100 fw-bold rounded-pill py-2">
                                XÁC NHẬN ĐÃ NHẬN TIỀN MẶT
                            </button>
                        </form>
                    }
                    else
                    {
                        <div class="alert alert-info text-center">
                            Chờ nhận viên xác nhận thanh toán bằng tiền mặt
                        </div>
                    }
                }

                @* Dem nguoc giu don *@
                <div class="text-center mb-3 mt-2">
                    <h5 class="fw-bold text-danger" id="countdown">10:00</h5>
                    <small class="text-muted">Thời gian giữ đơn</small>
                </div>

                @if (User.IsInRole("Customer"))
                {
                    <a asp-action="Track" asp-route-id="@order.Id"
                       class="btn btn-outline-primary w-100 rounded-pill mb-2">
                        Theo dõi đơn hàng
                    </a>
                }
                <a asp-controller="Home" asp-action="Index"
                   class="btn btn-link w-100 text-center text-muted text-decoration-none">
                    Về trang chủ
                </a>

            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        let t = 600;
        const el = document.getElementById('countdown');
        const timer = setInterval(() => {
            const m = Math.floor(t / 60), s = t % 60;
            el.textContent = `${m}:${s < 10 ? '0' + s : s}`;
            if (t <= 0) {
                clearInterval(timer);
                el.textContent = "Het thoi gian";
                el.classList.add("text-secondary");
            }
            t--;
        }, 1000);
    </script>
}
