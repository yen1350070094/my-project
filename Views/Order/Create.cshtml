@model MilkTeaShop.ViewModels.CreateOrderViewModel
@{
    ViewData["Title"] = "Đặt hàng - " + Model.Product?.Name;
}

<div class="row justify-content-center">
    <div class="col-lg-7">
        <div class="card shadow-sm border-0 rounded-3">
            <div class="card-header bg-white fw-bold border-0 pt-4">
                Đặt hàng: <span class="text-success">@Model.Product?.Name</span>
                <span class="text-muted small ms-2">Giá gốc: @Model.Product?.BasePrice.ToString("N0") đ</span>
            </div>
            <div class="card-body p-4">
                <form asp-action="Create" method="post">
                    <input type="hidden" asp-for="ProductId" />

                    <h6 class="fw-bold text-success mb-3">Thông tin khách hàng</h6>
                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <div class="form-floating">
                                <input asp-for="CustomerName" class="form-control" placeholder="Họ tên" required />
                                <label>Họ và tên</label>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-floating">
                                <input asp-for="CustomerPhone" class="form-control" placeholder="SĐT" required />
                                <label>Số điện thoại</label>
                            </div>
                        </div>
                    </div>
                    <div class="form-floating mb-4">
                        <input asp-for="CustomerAddress" class="form-control" placeholder="Địa chỉ" />
                        <label>Địa chỉ giao hàng</label>
                    </div>

                    <hr class="my-3">
                    <h6 class="fw-bold text-success mb-3">Tùy chỉnh sản phẩm</h6>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Kích cỡ (Size)</label>
                        <div class="d-flex gap-3 flex-wrap">
                            @foreach (var size in Model.Sizes)
                            {
                                <div class="form-check">
                                    <input class="form-check-input size-radio" type="radio"
                                           name="SelectedSizeId" id="size_@size.Id" value="@size.Id"
                                           data-price="@size.ExtraPrice"
                                    @(size == Model.Sizes.FirstOrDefault() ? "checked" : "") required />
                                    <label class="form-check-label btn btn-outline-secondary btn-sm px-3" for="size_@size.Id">
                                        @size.SizeName
                                        @if (size.ExtraPrice > 0)
                                        {
                                            <span class="text-muted">(+@size.ExtraPrice.ToString("N0")đ)</span>
                                        }
                                    </label>
                                </div>
                            }
                        </div>
                    </div>

                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Độ ngọt</label>
                            <select asp-for="SelectedSugarLevelId" class="form-select" required>
                                @foreach (var s in Model.SugarLevels)
                                {
                                    <option value="@s.Id" selected="@(s.Percentage == 100)">@s.Label</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Lượng đá</label>
                            <select asp-for="SelectedIceLevelId" class="form-select" required>
                                @foreach (var i in Model.IceLevels)
                                {
                                    <option value="@i.Id" selected="@(i.Percentage == 100)">@i.Label</option>
                                }
                            </select>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Topping (chọn nhiều)</label>
                        <div class="row g-2">
                            @foreach (var t in Model.Toppings)
                            {
                                <div class="col-6">
                                    <div class="form-check border rounded-3 p-2">
                                        <input class="form-check-input topping-check" type="checkbox"
                                               name="SelectedToppingIds" value="@t.Id"
                                               id="topping_@t.Id" data-price="@t.Price" />
                                        <label class="form-check-label" for="topping_@t.Id">
                                            @t.Name <span class="text-muted">(+@t.Price.ToString("N0")đ)</span>
                                        </label>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>

                    <div class="row g-3 mb-3">
                        <div class="col-md-4">
                            <label class="form-label fw-bold">Số lượng</label>
                            <input asp-for="Quantity" id="qty" type="number" min="1" max="99" class="form-control" />
                        </div>
                        <div class="col-md-8">
                            <label class="form-label fw-bold">Phuong thuc thanh toan</label>
                            <div class="d-flex gap-3 mt-1">
                                <div class="form-check border rounded-3 p-3 flex-fill text-center" id="card-cash">
                                    <input class="form-check-input" type="radio" name="PaymentMethod"
                                           id="pm-cash" value="Cash" checked onchange="updatePaymentUI()" />
                                    <label class="form-check-label d-block" for="pm-cash">
                                        <div class="fw-bold">Tien mat</div>
                                        <small class="text-muted">Thanh toan khi nhan</small>
                                    </label>
                                </div>
                                <div class="form-check border rounded-3 p-3 flex-fill text-center" id="card-momo">
                                    <input class="form-check-input" type="radio" name="PaymentMethod"
                                           id="pm-momo" value="Momo" onchange="updatePaymentUI()" />
                                    <label class="form-check-label d-block" for="pm-momo">
                                        <div class="fw-bold">Momo</div>
                                        <small class="text-muted">Quet QR thanh toan</small>
                                    </label>
                                </div>
                            </div>
                            <div id="note-cash" class="alert alert-warning small mt-2 mb-0 py-2">
                                Nhan vien se xac nhan sau khi ban thanh toan tien mat
                            </div>
                            <div id="note-momo" class="alert alert-success small mt-2 mb-0 py-2 d-none">
                                Thanh toan qua QR Momo - don hang duoc xac nhan ngay!
                            </div>
                        </div>
                    </div>

                    <div class="form-floating mb-4">
                        <textarea asp-for="Note" class="form-control" placeholder="Ghi chú" style="height:80px"></textarea>
                        <label>Ghi chú</label>
                    </div>

                    <div class="alert alert-success d-flex justify-content-between align-items-center fw-bold fs-5 mb-4">
                        <span>Tổng tiền dự kiến:</span>
                        <span id="totalPrice">@Model.Product?.BasePrice.ToString("N0") đ</span>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-success rounded-pill px-4 fw-bold flex-grow-1">
                            XÁC NHẬN ĐẶT HÀNG
                        </button>
                        <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4">Hủy</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const basePrice = @(Model.Product?.BasePrice ?? 0);
        // Tạo object mapping cho sizes
        const sizes = {
        @Html.Raw(string.Join(",", Model.Sizes.Select(s => $"{s.Id}:{s.ExtraPrice}")))
        };

        function updateTotal() {
            const sel = document.querySelector('.size-radio:checked');
            const sizeExtra = sel ? (sizes[sel.value] || 0) : 0;

            const toppingSum = [...document.querySelectorAll('.topping-check:checked')]
                .reduce((s, el) => s + parseFloat(el.dataset.price || 0), 0);

            const qty = parseInt(document.getElementById('qty').value) || 1;
            const total = (basePrice + sizeExtra + toppingSum) * qty;

            document.getElementById('totalPrice').textContent = total.toLocaleString('vi-VN') + ' đ';
        }

        document.querySelectorAll('.size-radio, .topping-check, #qty')
            .forEach(el => el.addEventListener('change', updateTotal));

        updateTotal();

        function updatePaymentUI() {
            const isMomo = document.getElementById('pm-momo').checked;
            document.getElementById('note-cash').classList.toggle('d-none', isMomo);
            document.getElementById('note-momo').classList.toggle('d-none', !isMomo);
            document.getElementById('card-cash').classList.toggle('border-success', !isMomo);
            document.getElementById('card-momo').classList.toggle('border-success', isMomo);
        }
        updatePaymentUI();
    </script>
}