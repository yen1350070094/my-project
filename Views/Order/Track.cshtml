@model MilkTeaShop.Models.Order
@{ ViewData["Title"] = "Theo dõi đơn - " + Model.OrderCode; }

<div class="row justify-content-center">
    <div class="col-lg-8">

        <!-- Header -->
        <div class="d-flex align-items-center gap-3 mb-4">
            <a asp-action="MyOrders" class="btn btn-outline-secondary btn-sm rounded-pill"> Quay lại</a>
            <div>
                <h4 class="fw-bold mb-0"> Theo dõi đơn hàng</h4>
                <small class="text-muted">Mã đơn: <strong class="text-success">@Model.OrderCode</strong></small>
            </div>
        </div>

        <!-- Thanh tiến trình -->
        @{
            var steps = new[] { "Pending", "Processing", "Completed" };
            var stepLabels = new[] { "Đã đặt", "Đang làm", "Hoàn thành" };
            var stepIcons  = new[] { "", "", "" };
            int currentStep = Model.Status == "Cancelled" ? -1 :
                              Model.Status == "Completed" ? 2 :
                              Model.Status == "Processing" ? 1 : 0;
        }

        @if (Model.Status == "Cancelled")
        {
            <div class="alert alert-danger text-center mb-4">
                <div style="font-size:2rem"></div>
                <strong>Đơn hàng đã bị hủy</strong>
                @if (!string.IsNullOrEmpty(Model.CancelReason))
                { <div class="small mt-1">Lý do: @Model.CancelReason</div> }
                @if (Model.PaymentStatus == "Refunded")
                { <div class="small text-info mt-1"> Tiền Momo sẽ được hoàn lại trong 1-3 ngày làm việc</div> }
            </div>
        }
        else
        {
            <div class="card border-0 shadow-sm rounded-3 mb-4 p-4">
                <div class="d-flex justify-content-between align-items-center">
                    @for (int s = 0; s < steps.Length; s++)
                    {
                        var isDone    = s <= currentStep;
                        var isActive  = s == currentStep;
                        <div class="text-center flex-fill">
                            <div class="rounded-circle mx-auto d-flex align-items-center justify-content-center fw-bold"
                                 style="width:48px;height:48px;font-size:1.3rem;
                                        background:@(isDone ? "#198754" : "#dee2e6");
                                        color:@(isDone ? "white" : "#6c757d")">
                                @stepIcons[s]
                            </div>
                            <div class="small mt-1 fw-bold @(isActive ? "text-success" : isDone ? "text-success" : "text-muted")">
                                @stepLabels[s]
                            </div>
                        </div>
                        @if (s < steps.Length - 1)
                        {
                            <div class="flex-fill" style="height:3px;margin-top:-24px;
                                 background:@(s < currentStep ? "#198754" : "#dee2e6")"></div>
                        }
                    }
                </div>
            </div>
        }

        <!-- Chi tiết đơn -->
        <div class="card border-0 shadow-sm rounded-3 mb-4">
            <div class="card-header bg-white fw-bold border-0 pt-3"> Chi tiết sản phẩm</div>
            <div class="card-body p-0">
                <table class="table table-sm align-middle mb-0">
                    <thead class="table-light">
                        <tr><th class="ps-3">Sản phẩm</th><th>Tùy chỉnh</th><th class="text-end pe-3">Tiền</th></tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.OrderItems)
                        {
                            <tr>
                                <td class="ps-3">
                                    <div class="fw-bold">@item.Product?.Name</div>
                                    <small class="text-muted">Size @item.ProductSize?.SizeName - x@item.Quantity</small>
                                </td>
                                <td class="small text-muted">
                                     @item.SugarLevel?.Label -  @item.IceLevel?.Label
                                    @if (item.OrderItemToppings.Any())
                                    {
                                        var toppingNames = string.Join(", ", item.OrderItemToppings.Select(t => t.Topping!.Name));
                                        <br />
                                        <span>+ @toppingNames</span>
                                    }
                                    @if (!string.IsNullOrEmpty(item.Note))
                                    { <br/><em>@item.Note</em> }
                                </td>
                                <td class="text-end pe-3 fw-bold">@item.Subtotal.ToString("N0") đ</td>
                            </tr>
                        }
                    </tbody>
                    <tfoot>
                        <tr class="table-success">
                            <td colspan="2" class="ps-3 fw-bold">Tổng cộng</td>
                            <td class="text-end pe-3 fw-bold fs-5">@Model.TotalAmount.ToString("N0") đ</td>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </div>

        <!-- Thanh toán -->
        <div class="card border-0 shadow-sm rounded-3 mb-4 p-4">
            <h6 class="fw-bold mb-3"> Thanh toán</h6>
            <div class="row">
                <div class="col-6">
                    <div class="text-muted small">Phương thức</div>
                    <div class="fw-bold">@(Model.PaymentMethod == "Momo" ? " Momo" : " Tiền mặt")</div>
                </div>
                <div class="col-6">
                    <div class="text-muted small">Trạng thái</div>
                    @if (Model.PaymentStatus == "Paid")
                    { <span class="badge bg-success fs-6"> Đã thanh toán</span> }
                    else if (Model.PaymentStatus == "Refunded")
                    { <span class="badge bg-info fs-6"> Đã hoàn tiền</span> }
                    else
                    { <span class="badge bg-warning text-dark fs-6"> Chờ thanh toán</span> }
                </div>
            </div>
            @if (Model.PaymentMethod == "Cash" && Model.PaymentStatus == "Unpaid" && Model.Status != "Cancelled")
            {
                <div class="alert alert-warning mt-3 small mb-0">
                     Vui lòng thanh toán tiền mặt cho nhân viên khi nhận hàng
                </div>
            }
        </div>

        <!-- Nút hủy đơn -->
        @if (Model.Status == "Pending")
        {
            <div class="card border-danger border-2 rounded-3 p-4">
                <h6 class="fw-bold text-danger mb-3"> Hủy đơn hàng</h6>
                <p class="small text-muted mb-3">
                    Bạn có thể hủy đơn khi nhân viên chưa xác nhận.
                    @if (Model.PaymentMethod == "Momo" && Model.PaymentStatus == "Paid")
                    { <strong class="text-info">Tiền Momo sẽ được hoàn lại trong 1-3 ngày làm việc.</strong> }
                    else if (Model.PaymentMethod == "Cash")
                    { <strong>Thanh toán tiền mặt sẽ được xử lý bình thường.</strong> }
                </p>
                <form asp-action="Cancel" method="post">
                    <input type="hidden" name="id" value="@Model.Id" />
                    <div class="input-group">
                        <input type="text" name="reason" class="form-control"
                               placeholder="Lý do hủy (tuỳ chọn)..." />
                        <button type="submit" class="btn btn-danger rounded-end"
                                onclick="return confirm('Bạn chắc chắn muốn hủy đơn này?')">
                            Hủy đơn
                        </button>
                    </div>
                </form>
            </div>
        }
    </div>
</div>
