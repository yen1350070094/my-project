@model MilkTeaShop.Models.Product
@{
    ViewData["Title"] = "Sửa sản phẩm";
}

<div class="card shadow-sm border-0 rounded-3" style="max-width:640px;margin:0 auto">
    <div class="card-header bg-white fw-bold border-0 pt-4">Chỉnh sửa sản phẩm</div>
    <div class="card-body">
        <form asp-action="Edit" method="post">
            <input type="hidden" asp-for="Id" />
            <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small"></div>

            <div class="mb-3">
                <label class="form-label fw-bold">Danh mục</label>
                <select asp-for="CategoryId" class="form-select" required>
                    <option value="">-- Chọn danh mục --</option>
                    @foreach (var c in ViewBag.Categories as IEnumerable<MilkTeaShop.Models.Category> ?? new List<MilkTeaShop.Models.Category>())
                    {
                        <option value="@c.Id">@c.Name</option>
                    }
                </select>
            </div>

            <div class="mb-3">
                <label class="form-label fw-bold">Tên sản phẩm</label>
                <input asp-for="Name" class="form-control" placeholder="VD: Trà sữa matcha" required />
            </div>

            <div class="mb-3">
                <label class="form-label fw-bold">Mô tả</label>
                <textarea asp-for="Description" class="form-control" rows="2" placeholder="Nhập mô tả sản phẩm..."></textarea>
            </div>

            <div class="mb-3">
                <label class="form-label fw-bold">Giá gốc (VNĐ)</label>
                <input asp-for="BasePrice" type="number" class="form-control" placeholder="35000" required />
            </div>

            <div class="mb-3">
                <label class="form-label fw-bold">Link ảnh (tùy chọn)</label>
                <input asp-for="ImageUrl" class="form-control" placeholder="https://..." />
            </div>

            <div class="mb-4">
                <label class="form-label fw-bold">Phụ phí theo kích cỡ (VNĐ)</label>
                <div class="row g-2">
                    <div class="col-4">
                        <div class="input-group">
                            <span class="input-group-text">S</span>
                            <input name="sizeS" type="number" class="form-control" value="0" />
                        </div>
                    </div>
                    <div class="col-4">
                        <div class="input-group">
                            <span class="input-group-text">M</span>
                            <input name="sizeM" type="number" class="form-control" value="5000" />
                        </div>
                    </div>
                    <div class="col-4">
                        <div class="input-group">
                            <span class="input-group-text">L</span>
                            <input name="sizeL" type="number" class="form-control" value="10000" />
                        </div>
                    </div>
                </div>
            </div>

            <div class="form-check mb-4">
                <input asp-for="IsAvailable" class="form-check-input" type="checkbox" />
                <label asp-for="IsAvailable" class="form-check-label">Sẵn sàng phục vụ (Còn hàng)</label>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-success rounded-pill px-4 fw-bold">Cập nhật</button>
                <a asp-action="Manage" class="btn btn-outline-secondary rounded-pill px-4">Hủy</a>
            </div>
        </form>
    </div>
</div>