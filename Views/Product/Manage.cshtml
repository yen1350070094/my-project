@model IEnumerable<MilkTeaShop.Models.Product>
@{
    ViewData["Title"] = "Quản lý sản phẩm";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="fw-bold mb-0">Quản lý sản phẩm</h3>
    <a asp-action="Create" class="btn btn-success rounded-pill px-4">
        + Thêm sản phẩm mới
    </a>
</div>

<div class="card shadow-sm border-0 rounded-3">
    <div class="card-body p-0">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th class="ps-4">#</th>
                    <th>Tên sản phẩm</th>
                    <th>Danh mục</th>
                    <th>Giá gốc</th>
                    <th>Kích cỡ</th>
                    <th class="text-center">Trạng thái</th>
                    <th class="text-center">Hành động</th>
                </tr>
            </thead>
            <tbody>
                @{
                    int i = 1;
                }
                @foreach (var p in Model)
                {
                    <tr class="@(!p.IsAvailable ? "table-secondary" : "")">
                        <td class="ps-4 text-muted">@i++</td>
                        <td>
                            <div class="d-flex align-items-center gap-2">
                                @if (!string.IsNullOrEmpty(p.ImageUrl))
                                {
                                    <img src="@p.ImageUrl" class="rounded" width="40" height="40" style="object-fit: cover;" />
                                }
                                else
                                {
                                    <div class="bg-light rounded d-flex align-items-center justify-content-center" style="width:40px; height:40px;">
                                        <small class="text-muted">No Alt</small>
                                    </div>
                                }
                                <div>
                                    <div class="fw-bold @(!p.IsAvailable ? "text-muted" : "")">@p.Name</div>
                                    <small class="text-muted">@p.Description</small>
                                </div>
                            </div>
                        </td>
                        <td><span class="badge bg-light text-dark border">@p.Category?.Name</span></td>
                        <td class="fw-bold text-success">@p.BasePrice.ToString("N0") đ</td>
                        <td>
                            @foreach (var s in p.Sizes)
                            {
                                <span class="badge bg-secondary me-1">@s.SizeName: +@s.ExtraPrice.ToString("N0")</span>
                            }
                        </td>
                        <td class="text-center">
                            @if (p.IsAvailable)
                            {
                                <span class="badge bg-success">Đang bán</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Tạm ngưng</span>
                            }
                        </td>
                        <td class="text-center">
                            <div class="d-flex gap-1 justify-content-center">
                                <a asp-action="Edit" asp-route-id="@p.Id"
                                   class="btn btn-sm btn-outline-primary" title="Sửa">Sửa</a>

                                <form asp-action="ToggleAvailable" method="post" class="d-inline">
                                    <input type="hidden" name="id" value="@p.Id" />
                                    @if (p.IsAvailable)
                                    {
                                        <button class="btn btn-sm btn-outline-warning" title="Đánh dấu hết hàng">Ẩn</button>
                                    }
                                    else
                                    {
                                        <button class="btn btn-sm btn-outline-success" title="Đánh dấu còn hàng">Hiện</button>
                                    }
                                </form>

                                @if (User.IsInRole("Manager") || User.IsInRole("Admin"))
                                {
                                    <form asp-action="Delete" method="post" class="d-inline"
                                          onsubmit="return confirm('Bạn chắc chắn muốn xóa sản phẩm @p.Name?')">
                                        <input type="hidden" name="id" value="@p.Id" />
                                        <button class="btn btn-sm btn-outline-danger" title="Xóa">Xóa</button>
                                    </form>
                                }
                            </div>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr><td colspan="7" class="text-center py-5 text-muted">Chưa có sản phẩm nào trong danh sách</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>