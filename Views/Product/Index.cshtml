@model IEnumerable<MilkTeaShop.Models.Product>
@{
    ViewData["Title"] = "Menu";
}

<div class="container py-5">
    <div class="text-center mb-5">
        <h2 class="fw-bold mb-0 text-uppercase tracking-wide">Menu Đồ Uống</h2>
        <div class="mx-auto bg-success mt-2" style="height: 3px; width: 50px;"></div>
    </div>

    <div class="row g-4">
        @foreach (var p in Model)
        {
            <div class="col-md-4 col-sm-6">
                <div class="card h-100 shadow-sm border-0 rounded-4 overflow-hidden product-card">
                    @* Placeholder cho hình ảnh sản phẩm *@
                    <div class="bg-light d-flex align-items-center justify-content-center" style="height:180px;">
                        @if (!string.IsNullOrEmpty(p.ImageUrl))
                        {
                            <img src="@p.ImageUrl" class="img-fluid h-100 w-100 object-fit-cover" alt="@p.Name" />
                        }
                        else
                        {
                            <i class="bi bi-cup-straw fs-1 text-muted opacity-50"></i>
                        }
                    </div>

                    <div class="card-body d-flex flex-column">
                        <div class="mb-2">
                            <span class="badge bg-success-subtle text-success border border-success-subtle px-2 py-1">
                                @(p.Category?.Name ?? "Đồ uống")
                            </span>
                        </div>

                        <h5 class="fw-bold mb-2">@p.Name</h5>
                        <p class="text-muted small flex-grow-1">
                            @(p.Description ?? "Hương vị thơm ngon đặc trưng, được pha chế từ nguyên liệu tươi sạch.")
                        </p>

                        <div class="d-flex justify-content-between align-items-center mt-3 pt-3 border-top">
                            <span class="fs-5 fw-bold text-success">@p.BasePrice.ToString("N0") đ</span>
                            <a href="/Order/Create?productId=@p.Id" class="btn btn-success rounded-pill px-4 fw-bold">
                                Đặt món
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<style>
    .product-card {
        transition: transform 0.2s ease-in-out;
    }

        .product-card:hover {
            transform: translateY(-5px);
        }

    .object-fit-cover {
        object-fit: cover;
    }
</style>