@model MilkTeaShop.Models.Customer
@{
    ViewData["Title"] = "Chi tiết khách hàng - " + Model.FullName;
}
<div class="container py-4">
    <a href="/Customer" class="btn btn-link text-decoration-none text-muted mb-3">Danh sách</a>
    <div class="row g-4">
        <div class="col-md-4">
            <div class="card shadow-sm border-0 rounded-4 p-4 text-center">
                <div class="display-1 mb-2"></div>
                <h4 class="fw-bold">@Model.FullName</h4>
                <p class="text-muted">@Model.Phone</p>
                <p class="text-muted">@(Model.Email ?? "Chưa có email")</p>
                <span class="badge bg-warning text-dark fs-6">@Model.LoyaltyPoints điểm</span>
                <p class="text-muted small mt-3">Ngày đăng ký: @Model.CreatedAt.ToString("dd/MM/yyyy")</p>
            </div>
        </div>
        <div class="col-md-8">
            <div class="card shadow-sm border-0 rounded-4">
                <div class="card-header fw-bold bg-light">Lịch sử đơn hàng (@Model.Orders.Count đơn)</div>
                <div class="card-body p-0">
                    <table class="table table-sm align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th class="ps-3">Mã đơn</th>
                                <th>Sản phẩm</th>
                                <th>Tổng tiền</th>
                                <th>Trạng thái</th>
                                <th>Ngày</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var o in Model.Orders.OrderByDescending(o => o.OrderedAt))
                            {
                                <tr>
                                    <td class="ps-3 fw-bold text-success small">@o.OrderCode</td>
                                    <td class="small">@string.Join(", ", o.OrderItems.Select(oi => oi.Product?.Name))</td>
                                    <td>@o.TotalAmount.ToString("N0") đ</td>
                                    <td><span class="badge @(o.Status == "Completed" ? "bg-success" : "bg-secondary")">@o.Status</span></td>
                                    <td><small class="text-muted">@o.OrderedAt.ToString("dd/MM HH:mm")</small></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>