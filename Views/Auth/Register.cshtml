@model MilkTeaShop.ViewModels.RegisterViewModel
@{
    ViewData["Title"] = "Đăng ký tài khoản";
}

<div class="card shadow-sm border-0" style="max-width:560px;margin:40px auto;border-radius:16px!important">

    <div class="card-header bg-white text-center pt-4 pb-0 border-0">
        <div style="font-size:3rem"></div>
        <h4 class="fw-bold">Tạo tài khoản mới</h4>
        <p class="text-muted">Đăng ký để đặt hàng và tích điểm!</p>
    </div>

    <div class="card-body px-4 pb-4">

        <form asp-action="Register" method="post">

            <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small"></div>

            <div class="form-floating mb-3">
                <input asp-for="FullName" class="form-control" placeholder="Họ tên" />
                <label asp-for="FullName">Họ và tên</label>
                <span asp-validation-for="FullName" class="text-danger small"></span>
            </div>

            <div class="row g-3 mb-3">
                <div class="col-6">
                    <div class="form-floating">
                        <input asp-for="Phone" class="form-control" placeholder="SĐT" />
                        <label asp-for="Phone">SĐT</label>
                        <span asp-validation-for="Phone" class="text-danger small"></span>
                    </div>
                </div>
                <div class="col-6">
                    <div class="form-floating">
                        <input asp-for="Email" class="form-control" placeholder="Email" />
                        <label asp-for="Email">Email</label>
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>
                </div>
            </div>

            <div class="form-floating mb-3">
                <input asp-for="Address" class="form-control" placeholder="Địa chỉ" />
                <label asp-for="Address">Địa chỉ giao hàng</label>
            </div>

            <div class="form-floating mb-3">
                <input asp-for="Password" class="form-control" placeholder="Mật khẩu" />
                <label asp-for="Password">Mật khẩu</label>
                <span asp-validation-for="Password" class="text-danger small"></span>
            </div>

            <div class="form-floating mb-4">
                <input asp-for="ConfirmPassword" class="form-control" placeholder="Xác nhận" />
                <label asp-for="ConfirmPassword">Xác nhận mật khẩu</label>
                <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
            </div>

            <button type="submit" class="btn btn-success w-100 py-2 fw-bold rounded-pill">
                Đăng ký
            </button>
        </form>

        <div class="d-flex align-items-center gap-2 my-3">
            <hr class="flex-fill">
            <span class="text-muted small">hoặc</span>
            <hr class="flex-fill">
        </div>

        <a asp-action="LoginGoogle"
           class="btn btn-outline-dark w-100 py-2 mb-3 rounded-pill d-flex align-items-center justify-content-center gap-2">

            <svg width="20" height="20" viewBox="0 0 48 48">
                <path fill="#EA4335" d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z" />
                <path fill="#4285F4" d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z" />
                <path fill="#FBBC05" d="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19z" />
                <path fill="#34A853" d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.15 1.45-4.92 2.3-8.16 2.3-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z" />
            </svg>

            Đăng ký với Google
        </a>

        <hr>

        <p class="text-center text-muted mb-0">
            Đã có tài khoản?
            <a asp-action="Login" class="text-success fw-bold">Đăng nhập</a>
        </p>

    </div>
</div>

