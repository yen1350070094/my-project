@model IEnumerable<MilkTeaShop.Models.Banner>

@{
    ViewData["Title"] = "Quản lý Banner";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="fw-bold mb-0"><i class="bi bi-images me-2 text-success"></i>Quản lý Banner</h4>
        <p class="text-muted small mb-0">Thêm, sửa, xóa banner hiển thị trên trang chủ</p>
    </div>
    <a asp-action="Create" class="btn btn-success rounded-pill px-4">
        <i class="bi bi-plus-lg me-1"></i> Thêm banner
    </a>
</div>

@if (!Model.Any())
{
    <div class="text-center py-5">
        <i class="bi bi-image text-muted" style="font-size:3rem;"></i>
        <p class="text-muted mt-2">Chưa có banner nào. Hãy thêm banner đầu tiên!</p>
        <a asp-action="Create" class="btn btn-success rounded-pill px-4">Thêm ngay</a>
    </div>
}
else
{
    <div class="card shadow-sm border-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th style="width:60px">Ảnh</th>
                        <th>Tiêu đề</th>
                        <th>Mô tả</th>
                        <th style="width:80px">Thứ tự</th>
                        <th style="width:100px">Trạng thái</th>
                        <th style="width:160px" class="text-end">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var b in Model)
                    {
                        <tr class="@(!b.IsActive ? "table-secondary" : "")">
                            <td>
                                @if (!string.IsNullOrEmpty(b.ImageUrl))
                                {
                                    <img src="@b.ImageUrl" alt="@b.Title"
                                         style="width:56px;height:40px;object-fit:cover;border-radius:6px;" />
                                }
                                else
                                {
                                    <div class="bg-light rounded d-flex align-items-center justify-content-center"
                                         style="width:56px;height:40px;">
                                        <i class="bi bi-image text-muted"></i>
                                    </div>
                                }
                            </td>
                            <td class="fw-semibold">@b.Title</td>
                            <td class="text-muted small">
                                @(b.Description?.Length > 60
                                    ? b.Description.Substring(0, 60) + "..."
                                    : b.Description)
                            </td>
                            <td class="text-center">@b.DisplayOrder</td>
                            <td>
                                <form asp-action="ToggleActive" method="post" class="d-inline">
                                    <input type="hidden" name="id" value="@b.Id" />
                                    @Html.AntiForgeryToken()
                                    <button type="submit"
                                            class="badge border-0 @(b.IsActive ? "bg-success" : "bg-secondary")"
                                            style="cursor:pointer;">
                                        @(b.IsActive ? "Hiển thị" : "Ẩn")
                                    </button>
                                </form>
                            </td>
                            <td class="text-end">
                                <a asp-action="Edit" asp-route-id="@b.Id"
                                   class="btn btn-sm btn-outline-primary rounded-pill me-1">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                @if (User.IsInRole("Admin") || User.IsInRole("Manager"))
                                {
                                    <form asp-action="Delete" method="post" class="d-inline"
                                          onsubmit="return confirm('Xóa banner này?')">
                                        <input type="hidden" name="id" value="@b.Id" />
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-outline-danger rounded-pill">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
